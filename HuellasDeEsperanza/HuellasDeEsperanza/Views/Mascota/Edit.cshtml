@model HuellasDeEsperanza.Models.Mascota

@{
    ViewData["Title"] = "Editar Mascota";
}

<div class="container mt-4">
    <h2>Editar Perfil de @Model.Nombre</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Edit" asp-antiforgery="false" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="UsuarioId" />
                <input type="hidden" asp-for="Imagen" />

                <div class="form-group mb-3">
                    <label asp-for="Nombre" class="control-label fw-bold"></label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Descripcion" class="control-label fw-bold">Descripción</label>
                    <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Descripcion" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label class="control-label fw-bold">Cambiar Foto Actual</label>
                    <input type="file" name="imagenArchivo" class="form-control" accept="image/*" />
                    <span class="text-muted small">Dejar en blanco si deseas mantener la foto actual.</span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Tamanio" class="control-label fw-bold">Tamaño</label>
                    <select asp-for="Tamanio" class="form-select" asp-items="Html.GetEnumSelectList<Tamanio>()"></select>
                    <span asp-validation-for="Tamanio" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Estado" class="control-label fw-bold">Estado Médico</label>
                    <select asp-for="Estado" class="form-select" asp-items="Html.GetEnumSelectList<EstadoMedico>()"></select>
                    <span asp-validation-for="Estado" class="text-danger"></span>
                </div>

                <div class="mb-3 p-3 bg-light rounded border">
                    <h6 class="fw-bold mb-2">Checklist Sanitario</h6>
                    <div class="form-check mb-1">
                        <input class="form-check-input" asp-for="EstaVacunada" />
                        <label class="form-check-label" asp-for="EstaVacunada">¿Está Vacunada?</label>
                    </div>
                    <div class="form-check mb-1">
                        <input class="form-check-input" asp-for="EstaCastrada" />
                        <label class="form-check-label" asp-for="EstaCastrada">¿Está Castrada?</label>
                    </div>
                    <div class="form-check mb-1">
                        <input class="form-check-input" asp-for="EstaDesparasitada" />
                        <label class="form-check-label" asp-for="EstaDesparasitada">¿Está Desparasitada?</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" asp-for="EstaDisponible" />
                        <label class="form-check-label" asp-for="EstaDisponible">¿Está Disponible para Adopción?</label>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <button type="submit" class="btn btn-primary">Guardar Cambios</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Volver al listado</a>
                </div>
            </form>
        </div>

        <div class="col-md-4 text-center">
            <label class="fw-bold d-block mb-2">Foto Actual en Servidor</label>
            @if (!string.IsNullOrEmpty(Model.Imagen))
            {
                <img src="~/images/mascotas/@Model.Imagen" class="img-fluid rounded border shadow-sm" style="max-height: 250px; object-fit: cover;" />
            }
            else
            {
                <div class="bg-light border text-muted py-5 rounded">Sin foto asignada</div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}