@model IEnumerable<HuellasDeEsperanza.Models.Mascota>

@{
    ViewData["Title"] = "Mascotas";
}

<h2>Mascotas</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Agregar mascota</a>
</p>

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>Foto</th>
            <th>Nombre</th>
            <th>Tipo</th>
            <th>Tamaño</th>
            <th>Estado</th>
            <th>Disponible</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var mascota in Model)
        {
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(mascota.Imagen))
                    {
                        <img src="~/images/mascotas/@mascota.Imagen"
                             alt="@mascota.Nombre"
                             style="width:70px;height:70px;object-fit:cover;border-radius:6px;" />
                    }
                    else
                    {
                        <span class="text-muted">Sin foto</span>
                    }
                </td>
                <td>@mascota.Nombre</td>
                <td>@mascota.TipoMascota</td>
                <td>@mascota.Tamanio</td>
                <td>@mascota.Estado</td>
                <td>
                    @if (mascota.EstaDisponible)
                    {
                        <span class="badge bg-success">Sí</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">No</span>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@mascota.Id" class="btn btn-sm btn-outline-secondary">Ver</a>
                    <a asp-action="Edit" asp-route-id="@mascota.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                    <a asp-action="Delete" asp-route-id="@mascota.Id" class="btn btn-sm btn-outline-danger">Eliminar</a>
                    <form asp-controller="Solicitud" asp-action="CrearSolicitud" method="post">
                        <input type="hidden" name="mascotaId" value="@mascota.Id" />

                        <button type="submit" class="btn btn-primary btn-lg mt-2">
                            Adoptar
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>