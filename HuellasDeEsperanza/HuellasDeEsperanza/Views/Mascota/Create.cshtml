@model HuellasDeEsperanza.Models.Mascota

@{
    ViewData["Title"] = "Registrar Mascota";
}

<div class="container mt-4">
    <h2>Agregar Nueva Mascota</h2>
    <h4>Formulario de Ingreso</h4>
    <hr />

    <div class="row">
        <div class="col-md-6">

            <form asp-action="Create" enctype="multipart/form-data">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-group mb-3">
                    <label asp-for="Nombre" class="control-label fw-bold"></label>
                    <input asp-for="Nombre" class="form-control" placeholder="Ej: Rocko" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Descripcion" class="control-label fw-bold"></label>

                    <textarea asp-for="Descripcion"
                              class="form-control"
                              rows="3"
                              placeholder="Detalles de salud, carácter, etc.">
                    </textarea>

                    <span asp-validation-for="Descripcion" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label class="control-label fw-bold">Foto de la Mascota</label>

                    <input type="file"
                           name="imagenArchivo"
                           class="form-control"
                           accept="image/*" />

                    <span class="text-muted small">
                        Formatos permitidos: JPG, PNG, WEBP.
                    </span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="TipoMascota" class="control-label fw-bold">
                        Especie
                    </label>

                    <select asp-for="TipoMascota"
                            class="form-select"
                            asp-items="Html.GetEnumSelectList<TipoMascota>()">
                    </select>

                    <span asp-validation-for="TipoMascota" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Tamanio" class="control-label fw-bold">
                        Tamaño
                    </label>

                    <select asp-for="Tamanio"
                            class="form-select"
                            asp-items="Html.GetEnumSelectList<Tamanio>()">
                    </select>

                    <span asp-validation-for="Tamanio" class="text-danger"></span>
                </div>

                <div class="mb-3 p-3 bg-light rounded border">

                    <h6 class="fw-bold mb-2">Checklist Sanitario</h6>

                    <div class="form-check mb-2">
                        <input class="form-check-input" asp-for="EstaVacunada" />

                        <label class="form-check-label" asp-for="EstaVacunada">
                            ¿Está Vacunada?
                        </label>
                    </div>

                    <div class="form-check mb-2">
                        <input class="form-check-input" asp-for="EstaCastrada" />

                        <label class="form-check-label" asp-for="EstaCastrada">
                            ¿Está Castrada?
                        </label>
                    </div>

                    <div class="form-check mb-2">
                        <input class="form-check-input" asp-for="EstaDesparasitada" />

                        <label class="form-check-label" asp-for="EstaDesparasitada">
                            ¿Está Desparasitada?
                        </label>
                    </div>

                </div>

                <div class="form-group mb-3">

                    <button type="submit" class="btn btn-primary">
                        Guardar Registro
                    </button>

                    <a asp-action="Index"
                       class="btn btn-outline-secondary">
                        Cancelar
                    </a>

                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}