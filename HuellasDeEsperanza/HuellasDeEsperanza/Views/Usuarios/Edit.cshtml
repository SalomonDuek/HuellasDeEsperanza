@model HuellasDeEsperanza.Models.Usuario

@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="container mt-4">
    <h2>Editar Perfil de @Model.Nombre</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Edit" asp-antiforgery="false" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">
                <label asp-for="Nombre" class="control-label"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>
                <div class="form-group mb-3">
                    <label class="control-label fw-bold">Cambiar Foto Actual</label>
                    <input type="file" name="imagenArchivo" class="form-control" accept="image/*" />
                    <span class="text-muted small">Dejar en blanco si deseas mantener la foto actual.</span>
                </div>
            <div class="form-group mb-3">
                <label asp-for="Edad" class="control-label"></label>
                    <input asp-for="Edad" class="form-control" min="0" />
                <span asp-validation-for="Edad" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Mail" class="control-label"></label>
                <input asp-for="Mail" class="form-control" />
                <span asp-validation-for="Mail" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Contrasenia" class="control-label"></label>
                <input asp-for="Contrasenia" class="form-control" />
                <span asp-validation-for="Contrasenia" class="text-danger"></span>
            </div>
            @* solo puede mod el rol el admin
                <div class="form-group mb-3"> 
                <label asp-for="Rol" class="control-label"></label>
                <select asp-for="Rol" class="form-control"></select>
                <span asp-validation-for="Rol" class="text-danger"></span>
            </div>
            *@
            
            <div class="form-group mb-3">
                <label asp-for="TipoVivienda" class="control-label"></label>
                    <select asp-for="TipoVivienda" class="form-select" asp-items="Html.GetEnumSelectList<TipoVivienda>()"></select>
                <span asp-validation-for="TipoVivienda" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="CantidadDeMascotas" class="control-label"></label>
                    <input asp-for="CantidadDeMascotas" class="form-control" min="0" />
                <span asp-validation-for="CantidadDeMascotas" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Direccion" class="control-label"></label>
                <input asp-for="Direccion" class="form-control" />
                <span asp-validation-for="Direccion" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                    <button type="submit" class="btn btn-primary">Guardar Cambios</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Volver al listado</a>
                </div>
        </form>
    </div>
        <div class="col-md-4 text-center">
            <label class="fw-bold d-block mb-2">Foto Actual en Servidor</label>
            @if (!string.IsNullOrEmpty(Model.Imagen))
            {
                <img src="~/images/usuarios/@Model.Imagen" class="img-fluid rounded border shadow-sm" style="max-height: 250px; object-fit: cover;" />
            }
            else
            {
                <div class="bg-light border text-muted py-5 rounded">Sin foto asignada</div>
            }
        </div>
    </div>
</div>



@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
