@model HuellasDeEsperanza.Models.Solicitud

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Solicitud</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Tipo)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Tipo)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Estado)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Estado)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.FechaCreacion)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.FechaCreacion)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.FechaAuditoria)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.FechaAuditoria)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.DetalleRechazo)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.DetalleRechazo)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Usuario)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Usuario.Contrasenia)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Mascota)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Mascota.Descripcion)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.AuditadoPor)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.AuditadoPor.Contrasenia)
        </dd>
    </dl>
</div>
<div>
    
    <a asp-action="Index">Volver al listado</a>
    @if (Model.Estado == EstadoSolicitud.Pendiente)
    {
        <form asp-action="Verificar" method="post" class="d-inline">
            <input type="hidden" name="id" value="@Model.Id" />

            <button type="submit" class="btn btn-success btn-sm">
                Verificar
            </button>
        </form>
    }
</div>
